{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",
    "module": "node16",
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "moduleResolution": "node16",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["**/*.ts"]
}
