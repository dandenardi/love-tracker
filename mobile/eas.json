{
  "cli": {
    "version": ">= 18.5.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "node": "22.14.0",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "API_URL": "http://192.168.0.107:3001"
      }
    },
    "preview": {
      "node": "22.14.0",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "API_URL": "https://love-tracker-server.onrender.com"
      }
    },
    "production": {
      "node": "22.14.0",
      "distribution": "store",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "API_URL": "https://love-tracker-server.onrender.com"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "releaseStatus": "draft"
      }
    }
  }
}
